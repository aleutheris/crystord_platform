---
import MainLayout from "../layouts/MainLayout.astro";
import FormField from "../components/ui/FormField.astro";
import { siteConfig } from "../config/site";
---

<MainLayout title="Home">

  <!-- 1. Hero -->
  <section class="hero">
    <h1>Welcome to Crystord</h1>
    <p class="hero-sub">
      Your comprehensive control and monitoring solution. Experience powerful analytics,
      real-time monitoring, and intuitive controls all in one place.
    </p>
  </section>

  <!-- 2. Auth + Demo -->
  <section class="panel actions-panel">
    <div class="actions-grid">

      <!-- Auth card -->
      <div class="auth-card">
        <div class="auth-tabs" role="tablist">
          <button class="tab-btn active" data-tab="signin" role="tab" aria-selected="true">Sign In</button>
          <button class="tab-btn" data-tab="signup" role="tab" aria-selected="false">Sign Up</button>
        </div>

        <!-- Sign In panel -->
        <div class="tab-panel action-signin" id="tab-signin">
          <h2 class="card-title">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            Sign In
          </h2>
          <p class="card-sub">Access your account to continue</p>
          <form class="sign-in-form" data-graphql-url={siteConfig.graphqlUrl} novalidate>
            <FormField label="Email" name="si-email" type="email" required autocomplete="email" />
            <FormField label="Password" name="si-password" type="password" required autocomplete="current-password" />
            <p class="sign-in-error" hidden aria-live="polite"></p>
            <button type="submit" class="btn btn-primary form-btn">Sign In</button>
          </form>
          <div class="divider"><span>or sign in with</span></div>
          <div class="google-btn-wrap" id="google-signin-btn"></div>
          <p class="auth-switch">Don't have an account? <button class="link-btn" data-switch="signup">Create one</button></p>
        </div>

        <!-- Sign Up panel -->
        <div class="tab-panel hidden" id="tab-signup">
          <h2 class="card-title">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            Create Account
          </h2>
          <p class="card-sub">Create your account to get started</p>
          <form class="sign-up-form" data-graphql-url={siteConfig.graphqlUrl} novalidate>
            <FormField label="Email" name="su-email" type="email" required autocomplete="email" />
            <FormField label="Password" name="su-password" type="password" required autocomplete="new-password" />
            <FormField label="Confirm Password" name="su-confirm" type="password" required autocomplete="new-password" />
            <p class="sign-up-error" hidden aria-live="polite"></p>
            <button type="submit" class="btn btn-primary form-btn">Create Account</button>
          </form>
          <div class="divider"><span>or sign up with</span></div>
          <div class="google-btn-wrap" id="google-signup-btn"></div>
          <p class="auth-switch">Already have an account? <button class="link-btn" data-switch="signin">Sign in</button></p>
        </div>
      </div>

      <!-- Try Demo card -->
      <div class="demo-card">
        <h2 class="card-title demo-title">
          <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
          Try Demo
        </h2>
        <p class="card-sub">Explore all features with sample data</p>
        <ul class="demo-features">
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--green)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Interactive Dashboard
          </li>
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--green)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Real-time Charts &amp; Analytics
          </li>
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--green)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Control Panels
          </li>
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--green)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            User Management (View Only)
          </li>
        </ul>
        <button type="button" class="btn btn-primary demo-btn" id="demo-start-btn" data-graphql-url={siteConfig.graphqlUrl}>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
          Start Demo
        </button>
        <p class="demo-error" hidden aria-live="polite"></p>
        <p class="demo-note">No registration required</p>
      </div>

    </div>
  </section>

  <!-- 3. Why Crystord -->
  <section class="overview panel">
    <h2 class="section-title">Why Crystord?</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon" style="color: var(--brand);">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <h5>Live data in your slides</h5>
        <p>Values from your Sheets update your Slides instantly — no manual copying, no outdated decks.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="color: var(--green);">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h5>Works where you work</h5>
        <p>Runs entirely inside Google Workspace as an Add-on; no separate install or account beyond your Google login.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="color: var(--brand-dark);">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h5>Your data stays yours</h5>
        <p>All processing happens within Google's infrastructure. Nothing is stored on external servers.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="color: var(--gold);">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h5>Built for recurring use</h5>
        <p>Perfect for live reports, budget decks, executive dashboards, and project trackers that need to stay current.</p>
      </div>
    </div>
  </section>

  <!-- 4. Connect With Us -->
  <section class="panel connect-panel">
    <h2 class="section-title">Get in Touch</h2>
    <p class="section-sub">Stay updated and get the most out of Crystord</p>
    <div class="connect-grid">

      <div class="connect-card">
        <div class="connect-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="#FF0000"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </div>
        <h6>YouTube</h6>
        <p>Watch tutorials, demos, and feature updates</p>
        <a class="btn btn-connect btn-yt" href={siteConfig.youtubeUrl} target="_blank" rel="noopener noreferrer" aria-label="YouTube">Subscribe</a>
      </div>

      <div class="connect-card">
        <div class="connect-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="var(--brand)" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2 4 12 13 22 4"/></svg>
        </div>
        <h6>Newsletter</h6>
        <p>Get the latest updates and tips delivered to your inbox</p>
        <a class="btn btn-connect btn-newsletter" href={siteConfig.newsletterUrl} target="_blank" rel="noopener noreferrer">Subscribe</a>
      </div>

      <div class="connect-card">
        <div class="connect-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="var(--green)" stroke-width="1.5"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5l6.74-6.76z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/></svg>
        </div>
        <h6>Google Add-on</h6>
        <p>Enhance your Google Slides™ with our powerful add-on</p>
        <a class="btn btn-connect btn-addon" href="/google-addon">Learn More</a>
      </div>

      <div class="connect-card">
        <div class="connect-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="var(--muted)" stroke-width="1.5"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2z"/><polyline points="2 4 12 13 22 4"/></svg>
        </div>
        <h6>Contact Us</h6>
        <p>Do you have questions? We're here to help!</p>
        <a class="btn btn-connect btn-contact" href="/contact">Email Us</a>
      </div>

    </div>
  </section>
</MainLayout>

<style>
  /* Hero */
  .hero {
    padding: 0rem 0 2rem;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-bottom: 0.75rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 56ch;
    line-height: 1.6;
    margin: 0;
  }

  /* Actions grid */
  .actions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  /* Auth card */
  .auth-tabs {
    display: flex;
    border-bottom: 2px solid var(--line);
    margin-bottom: 1.25rem;
  }

  .tab-btn {
    flex: 1;
    padding: 0.6rem;
    background: none;
    border: none;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--muted);
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
    font-family: inherit;
  }

  .tab-btn.active {
    color: var(--brand);
    border-bottom-color: var(--brand);
  }

  .tab-panel.hidden {
    display: none;
  }

  .card-title {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .card-sub {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .sign-in-form,
  .sign-up-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sign-in-error,
  .sign-up-error {
    color: var(--error);
    margin: 0;
    font-size: 0.9rem;
  }

  .form-btn {
    align-self: flex-start;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-family: inherit;
    margin-top: 0.25rem;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1rem 0 0.75rem;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .divider::before,
  .divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  .auth-switch {
    margin: 0.75rem 0 0;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .link-btn {
    background: none;
    border: none;
    color: var(--brand);
    cursor: pointer;
    font-size: inherit;
    font-family: inherit;
    text-decoration: underline;
    padding: 0;
  }

  .icon-sm {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* Demo card */
  .demo-card {
    border-left: 1px solid var(--line);
    padding-left: 2.5rem;
  }

  .demo-title {
    color: var(--brand);
  }

  .demo-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .demo-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: var(--ink);
  }

  .demo-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .demo-note {
    margin: 0.6rem 0 0;
    font-size: 0.82rem;
    color: var(--muted);
  }

  /* Why section */
  .section-title {
    text-align: center;
    margin-bottom: 0.25rem;
  }

  .section-sub {
    text-align: center;
    color: var(--muted);
    margin: 0 0 1.5rem;
    font-size: 0.95rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .feature-card {
    text-align: center;
    padding: 1rem 0.5rem;
  }

  .feature-icon {
    margin-bottom: 0.75rem;
  }

  .feature-card h5 {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: var(--ink);
  }

  .feature-card p {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Connect section */
  .connect-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .connect-card {
    background: var(--surface);
    border-radius: 12px;
    padding: 1.25rem 1rem;
    text-align: center;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .connect-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }

  .connect-icon {
    margin-bottom: 0.65rem;
  }

  .connect-card h6 {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.35rem;
    color: var(--ink);
  }

  .connect-card p {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.4;
    margin: 0 0 0.85rem;
  }

  .btn-connect {
    font-size: 0.82rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    display: inline-block;
    border: 1.5px solid transparent;
    transition: opacity 0.15s;
  }

  .btn-connect:hover { opacity: 0.85; }

  .btn-yt        { border-color: #FF0000; color: #FF0000; background: transparent; }
  .btn-newsletter { border-color: var(--brand); color: var(--brand); background: transparent; }
  .btn-addon     { border-color: var(--green); color: var(--green); background: transparent; }
  .btn-contact   { border-color: var(--muted); color: var(--muted); background: transparent; }

  /* Responsive */
  @media (max-width: 768px) {
    .features-grid,
    .connect-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .actions-grid {
      grid-template-columns: 1fr;
    }

    .demo-card {
      border-left: none;
      border-top: 1px solid var(--line);
      padding-left: 0;
      padding-top: 1.5rem;
    }

    .features-grid,
    .connect-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 400px) {
    .features-grid,
    .connect-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Auth tabs
  const tabBtns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
  const tabPanels = document.querySelectorAll<HTMLDivElement>(".tab-panel");

  function switchTab(tabId: string) {
    tabBtns.forEach((btn) => {
      btn.classList.toggle("active", btn.dataset.tab === tabId);
      btn.setAttribute("aria-selected", String(btn.dataset.tab === tabId));
    });
    tabPanels.forEach((panel) => {
      panel.classList.toggle("hidden", panel.id !== `tab-${tabId}`);
    });
  }

  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => switchTab(btn.dataset.tab!));
  });

  document.querySelectorAll<HTMLButtonElement>(".link-btn").forEach((btn) => {
    btn.addEventListener("click", () => switchTab(btn.dataset.switch!));
  });

  // Auth utilities
  import { gqlSignIn, gqlSignUp, gqlSignInGoogle, getGoogleClientId } from "../utils/auth-graphql";
  import { loadGsi, initGoogleButton } from "../utils/google-auth";
  import { siteConfig } from "../config/site";

  const DEMO_EMAIL = "demo";
  const DEMO_PASSWORD = "demo";

  function appRedirect(graphqlUrl: string, token: string) {
    window.location.href = `${new URL(graphqlUrl).origin}/?token=${token}`;
  }

  // Sign-in form
  const signInForm = document.querySelector<HTMLFormElement>(".sign-in-form");
  if (signInForm) {
    const graphqlUrl = signInForm.dataset.graphqlUrl!;
    const errorEl = signInForm.querySelector<HTMLParagraphElement>(".sign-in-error")!;
    const submitBtn = signInForm.querySelector<HTMLButtonElement>("button[type=submit]")!;

    async function doSignIn(email: string, password: string, busyLabel: string) {
      errorEl.hidden = true;
      submitBtn.disabled = true;
      submitBtn.textContent = busyLabel;
      try {
        const result = await gqlSignIn(graphqlUrl, email, password);
        if (result.ok) {
          appRedirect(graphqlUrl, result.token);
        } else {
          errorEl.textContent = result.message;
          errorEl.hidden = false;
          submitBtn.disabled = false;
          submitBtn.textContent = "Sign In";
        }
      } catch {
        errorEl.textContent = "Unable to reach the sign-in service. Please try again.";
        errorEl.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = "Sign In";
      }
    }

    signInForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const email = signInForm.querySelector<HTMLInputElement>("#si-email")!.value.trim();
      const password = signInForm.querySelector<HTMLInputElement>("#si-password")!.value;
      doSignIn(email, password, "Signing in…");
    });
  }

  // Sign-up form
  const signUpForm = document.querySelector<HTMLFormElement>(".sign-up-form");
  if (signUpForm) {
    const graphqlUrl = signUpForm.dataset.graphqlUrl!;
    const errorEl = signUpForm.querySelector<HTMLParagraphElement>(".sign-up-error")!;
    const submitBtn = signUpForm.querySelector<HTMLButtonElement>("button[type=submit]")!;

    signUpForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = signUpForm.querySelector<HTMLInputElement>("#su-email")!.value.trim();
      const password = signUpForm.querySelector<HTMLInputElement>("#su-password")!.value;
      const confirm = signUpForm.querySelector<HTMLInputElement>("#su-confirm")!.value;

      if (password !== confirm) {
        errorEl.textContent = "Passwords do not match.";
        errorEl.hidden = false;
        return;
      }

      errorEl.hidden = true;
      submitBtn.disabled = true;
      submitBtn.textContent = "Creating account…";

      try {
        const result = await gqlSignUp(graphqlUrl, email, password);
        if (result.ok) {
          window.location.href = `${new URL(graphqlUrl).origin}/?token=${result.token}`;
        } else {
          errorEl.textContent = result.message;
          errorEl.hidden = false;
          submitBtn.disabled = false;
          submitBtn.textContent = "Create Account";
        }
      } catch {
        errorEl.textContent = "Unable to reach the sign-up service. Please try again.";
        errorEl.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = "Create Account";
      }
    });
  }

  // Demo button
  const demoBtn = document.querySelector<HTMLButtonElement>("#demo-start-btn");
  if (demoBtn) {
    const graphqlUrl = demoBtn.dataset.graphqlUrl!;
    const errorEl = demoBtn.nextElementSibling as HTMLParagraphElement;

    demoBtn.addEventListener("click", async () => {
      errorEl.hidden = true;
      demoBtn.disabled = true;
      demoBtn.textContent = "Loading demo…";

      try {
        const result = await gqlSignIn(graphqlUrl, DEMO_EMAIL, DEMO_PASSWORD);
        if (result.ok) {
          window.location.href = `${new URL(graphqlUrl).origin}/?token=${result.token}`;
        } else {
          errorEl.textContent = result.message;
          errorEl.hidden = false;
          demoBtn.disabled = false;
          demoBtn.textContent = "Start Demo";
        }
      } catch {
        errorEl.textContent = "Unable to reach the service. Please try again.";
        errorEl.hidden = false;
        demoBtn.disabled = false;
        demoBtn.textContent = "Start Demo";
      }
    });
  }

  // Google Sign-In buttons
  const graphqlUrlForGsi =
    (document.querySelector<HTMLElement>("[data-graphql-url]") as HTMLElement | null)
      ?.dataset.graphqlUrl ?? "https://app.crystord.com/graphql";

  async function handleGoogleToken(idToken: string) {
    const result = await gqlSignInGoogle(graphqlUrlForGsi, idToken);
    if (result.ok) {
      window.location.href = `${new URL(graphqlUrlForGsi).origin}/?token=${result.token}`;
    }
  }

  loadGsi()
    .then(() => siteConfig.googleClientId || getGoogleClientId(graphqlUrlForGsi))
    .then((clientId) => {
      const signinContainer = document.getElementById("google-signin-btn") as HTMLDivElement | null;
      const signupContainer = document.getElementById("google-signup-btn") as HTMLDivElement | null;
      if (signinContainer) initGoogleButton(clientId, signinContainer, handleGoogleToken);
      if (signupContainer) initGoogleButton(clientId, signupContainer, handleGoogleToken);
    })
    .catch(() => {
      // Google button unavailable — email/password path still works
    });
</script>
