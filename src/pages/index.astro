---
import MainLayout from "../layouts/MainLayout.astro";
import { siteConfig } from "../config/site";
---

<MainLayout title="Home">

  <!-- 1. Hero -->
  <section class="hero">
    <img src="/logo_negated.png" alt="Crystord Logo" class="hero-logo" />
    <h1>Welcome to Crystord</h1>
    <p class="hero-sub">
      Your comprehensive control and monitoring solution. Experience powerful analytics,
      real-time monitoring, and intuitive controls all in one place.
    </p>
  </section>

  <!-- 2. Auth + Demo -->
  <section class="panel actions-panel">
    <div class="actions-grid">

      <!-- Auth card -->
      <div class="auth-card">
        <div class="auth-tabs" role="tablist">
          <button class="tab-btn active" data-tab="signin" role="tab" aria-selected="true">Sign In</button>
          <button class="tab-btn" data-tab="signup" role="tab" aria-selected="false">Sign Up</button>
        </div>

        <!-- Sign In panel -->
        <div class="tab-panel" id="tab-signin">
          <h2 class="card-title">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            Sign In
          </h2>
          <p class="card-sub">Access your account to continue</p>
          <form class="sign-in-form" data-auth-url={siteConfig.appSignInUrl} novalidate>
            <div class="form-field">
              <label for="si-email">Email</label>
              <input id="si-email" name="email" type="email" required autocomplete="email" />
            </div>
            <div class="form-field">
              <label for="si-password">Password</label>
              <input id="si-password" name="password" type="password" required autocomplete="current-password" />
            </div>
            <p class="sign-in-error" hidden aria-live="polite"></p>
            <button type="submit" class="btn btn-primary form-btn">Sign In</button>
          </form>
          <div class="divider"><span>or sign in with</span></div>
          <div class="google-btn-wrap">
            <a href={siteConfig.appSignInUrl + "?provider=google"} class="btn-google">
              <svg viewBox="0 0 24 24" width="18" height="18"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
              Continue with Google
            </a>
          </div>
          <p class="auth-switch">Don't have an account? <button class="link-btn" data-switch="signup">Create one</button></p>
        </div>

        <!-- Sign Up panel -->
        <div class="tab-panel hidden" id="tab-signup">
          <h2 class="card-title">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            Create Account
          </h2>
          <p class="card-sub">Create your account to get started</p>
          <form class="sign-up-form" data-auth-url={siteConfig.appSignUpUrl} novalidate>
            <div class="form-field">
              <label for="su-email">Email</label>
              <input id="su-email" name="email" type="email" required autocomplete="email" />
            </div>
            <div class="form-field">
              <label for="su-password">Password</label>
              <input id="su-password" name="password" type="password" required autocomplete="new-password" />
            </div>
            <div class="form-field">
              <label for="su-confirm">Confirm Password</label>
              <input id="su-confirm" name="confirmPassword" type="password" required autocomplete="new-password" />
            </div>
            <p class="sign-up-error" hidden aria-live="polite"></p>
            <button type="submit" class="btn btn-primary form-btn">Create Account</button>
          </form>
          <div class="divider"><span>or sign up with</span></div>
          <div class="google-btn-wrap">
            <a href={siteConfig.appSignUpUrl + "?provider=google"} class="btn-google">
              <svg viewBox="0 0 24 24" width="18" height="18"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
              Continue with Google
            </a>
          </div>
          <p class="auth-switch">Already have an account? <button class="link-btn" data-switch="signin">Sign in</button></p>
        </div>
      </div>

      <!-- Try Demo card -->
      <div class="demo-card">
        <h2 class="card-title demo-title">
          <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
          Try Demo
        </h2>
        <p class="card-sub">Explore all features with sample data</p>
        <ul class="demo-features">
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--green)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Interactive Dashboard
          </li>
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--green)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Real-time Charts &amp; Analytics
          </li>
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--green)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Control Panels
          </li>
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--green)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            User Management (View Only)
          </li>
        </ul>
        <a class="btn btn-primary demo-btn" href={siteConfig.appDemoUrl}>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
          Start Demo
        </a>
        <p class="demo-note">No registration required</p>
      </div>

    </div>
  </section>

  <!-- 3. Why Crystord -->
  <section class="overview panel">
    <h2 class="section-title">Why Crystord?</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon" style="color: var(--brand);">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <h5>Live data in your slides</h5>
        <p>Values from your Sheets update your Slides instantly — no manual copying, no outdated decks.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="color: var(--green);">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h5>Works where you work</h5>
        <p>Runs entirely inside Google Workspace as an Add-on; no separate install or account beyond your Google login.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="color: var(--brand-dark);">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h5>Your data stays yours</h5>
        <p>All processing happens within Google's infrastructure. Nothing is stored on external servers.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="color: var(--gold);">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h5>Built for recurring use</h5>
        <p>Perfect for live reports, budget decks, executive dashboards, and project trackers that need to stay current.</p>
      </div>
    </div>
  </section>

  <!-- 4. Connect With Us -->
  <section class="panel connect-panel">
    <h2 class="section-title">Get in Touch</h2>
    <p class="section-sub">Stay updated and get the most out of Crystord</p>
    <div class="connect-grid">

      <div class="connect-card">
        <div class="connect-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="#FF0000"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </div>
        <h6>YouTube</h6>
        <p>Watch tutorials, demos, and feature updates</p>
        <a class="btn btn-connect btn-yt" href={siteConfig.youtubeUrl} target="_blank" rel="noopener noreferrer">Subscribe</a>
      </div>

      <div class="connect-card">
        <div class="connect-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="var(--brand)" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2 4 12 13 22 4"/></svg>
        </div>
        <h6>Newsletter</h6>
        <p>Get the latest updates and tips delivered to your inbox</p>
        <a class="btn btn-connect btn-newsletter" href={siteConfig.newsletterUrl} target="_blank" rel="noopener noreferrer">Subscribe</a>
      </div>

      <div class="connect-card">
        <div class="connect-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="var(--green)" stroke-width="1.5"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5l6.74-6.76z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/></svg>
        </div>
        <h6>Google Add-on</h6>
        <p>Enhance your Google Slides™ with our powerful add-on</p>
        <a class="btn btn-connect btn-addon" href="/google-addon">Learn More</a>
      </div>

      <div class="connect-card">
        <div class="connect-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="var(--muted)" stroke-width="1.5"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2z"/><polyline points="2 4 12 13 22 4"/></svg>
        </div>
        <h6>Contact Us</h6>
        <p>Do you have questions? We're here to help!</p>
        <a class="btn btn-connect btn-contact" href="/contact">Email Us</a>
      </div>

    </div>
  </section>

</MainLayout>

<style>
  /* Hero */
  .hero {
    padding: 3rem 0 2rem;
    text-align: center;
  }

  .hero-logo {
    max-height: 72px;
    margin-bottom: 1.5rem;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-bottom: 0.75rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 56ch;
    line-height: 1.6;
    margin: 0 auto;
  }

  /* Actions grid */
  .actions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  /* Auth card */
  .auth-tabs {
    display: flex;
    border-bottom: 2px solid var(--line);
    margin-bottom: 1.25rem;
  }

  .tab-btn {
    flex: 1;
    padding: 0.6rem;
    background: none;
    border: none;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--muted);
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
    font-family: inherit;
  }

  .tab-btn.active {
    color: var(--brand);
    border-bottom-color: var(--brand);
  }

  .tab-panel.hidden {
    display: none;
  }

  .card-title {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .card-sub {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .sign-in-form,
  .sign-up-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .form-field label {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .form-field input {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
    font-size: 1rem;
    font-family: inherit;
    color: var(--ink);
    background: var(--surface);
  }

  .form-field input:focus {
    outline: 2px solid var(--brand);
    outline-offset: 1px;
    border-color: var(--brand);
  }

  .sign-in-error,
  .sign-up-error {
    color: var(--error);
    margin: 0;
    font-size: 0.9rem;
  }

  .form-btn {
    align-self: flex-start;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-family: inherit;
    margin-top: 0.25rem;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1rem 0 0.75rem;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .divider::before,
  .divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  .btn-google {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.55rem 1rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--white);
    color: var(--ink);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, box-shadow 0.15s;
  }

  .btn-google:hover {
    background: var(--surface);
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
  }

  .auth-switch {
    margin: 0.75rem 0 0;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .link-btn {
    background: none;
    border: none;
    color: var(--brand);
    cursor: pointer;
    font-size: inherit;
    font-family: inherit;
    text-decoration: underline;
    padding: 0;
  }

  .icon-sm {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* Demo card */
  .demo-card {
    border-left: 1px solid var(--line);
    padding-left: 2.5rem;
  }

  .demo-title {
    color: var(--brand);
  }

  .demo-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .demo-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: var(--ink);
  }

  .demo-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .demo-note {
    margin: 0.6rem 0 0;
    font-size: 0.82rem;
    color: var(--muted);
  }

  /* Why section */
  .section-title {
    text-align: center;
    margin-bottom: 0.25rem;
  }

  .section-sub {
    text-align: center;
    color: var(--muted);
    margin: 0 0 1.5rem;
    font-size: 0.95rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .feature-card {
    text-align: center;
    padding: 1rem 0.5rem;
  }

  .feature-icon {
    margin-bottom: 0.75rem;
  }

  .feature-card h5 {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: var(--ink);
  }

  .feature-card p {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Connect section */
  .connect-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .connect-card {
    background: var(--surface);
    border-radius: 12px;
    padding: 1.25rem 1rem;
    text-align: center;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .connect-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }

  .connect-icon {
    margin-bottom: 0.65rem;
  }

  .connect-card h6 {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.35rem;
    color: var(--ink);
  }

  .connect-card p {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.4;
    margin: 0 0 0.85rem;
  }

  .btn-connect {
    font-size: 0.82rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    display: inline-block;
    border: 1.5px solid transparent;
    transition: opacity 0.15s;
  }

  .btn-connect:hover { opacity: 0.85; }

  .btn-yt        { border-color: #FF0000; color: #FF0000; background: transparent; }
  .btn-newsletter { border-color: var(--brand); color: var(--brand); background: transparent; }
  .btn-addon     { border-color: var(--green); color: var(--green); background: transparent; }
  .btn-contact   { border-color: var(--muted); color: var(--muted); background: transparent; }

  /* Responsive */
  @media (max-width: 768px) {
    .features-grid,
    .connect-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .actions-grid {
      grid-template-columns: 1fr;
    }

    .demo-card {
      border-left: none;
      border-top: 1px solid var(--line);
      padding-left: 0;
      padding-top: 1.5rem;
    }

    .features-grid,
    .connect-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 400px) {
    .features-grid,
    .connect-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Auth tabs
  const tabBtns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
  const tabPanels = document.querySelectorAll<HTMLDivElement>(".tab-panel");

  function switchTab(tabId: string) {
    tabBtns.forEach((btn) => {
      btn.classList.toggle("active", btn.dataset.tab === tabId);
      btn.setAttribute("aria-selected", String(btn.dataset.tab === tabId));
    });
    tabPanels.forEach((panel) => {
      panel.classList.toggle("hidden", panel.id !== `tab-${tabId}`);
    });
  }

  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => switchTab(btn.dataset.tab!));
  });

  document.querySelectorAll<HTMLButtonElement>(".link-btn").forEach((btn) => {
    btn.addEventListener("click", () => switchTab(btn.dataset.switch!));
  });

  // Sign in form
  import { submitSignIn } from "../utils/sign-in";

  document.querySelectorAll<HTMLFormElement>(".sign-in-form").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const authUrl = form.dataset.authUrl!;
      const email = form.querySelector<HTMLInputElement>("#si-email")!.value.trim();
      const password = form.querySelector<HTMLInputElement>("#si-password")!.value;
      const errorEl = form.querySelector<HTMLParagraphElement>(".sign-in-error")!;
      const submitBtn = form.querySelector<HTMLButtonElement>("button[type=submit]")!;

      errorEl.hidden = true;
      submitBtn.disabled = true;
      submitBtn.textContent = "Signing in…";

      try {
        const result = await submitSignIn(authUrl, email, password);
        if (result.ok) {
          window.location.href = result.redirectUrl;
        } else {
          errorEl.textContent = result.message;
          errorEl.hidden = false;
          submitBtn.disabled = false;
          submitBtn.textContent = "Sign In";
        }
      } catch {
        errorEl.textContent = "Unable to reach the sign-in service. Please try again.";
        errorEl.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = "Sign In";
      }
    });
  });
</script>
