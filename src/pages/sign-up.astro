---
import MainLayout from "../layouts/MainLayout.astro";
import SignUpForm from "../components/SignUpForm.astro";
import { siteConfig } from "../config/site";
---

<MainLayout title="Sign Up">
  <section class="panel">
    <h1>Create your Crystord account</h1>
    <p class="page-sub">Already have an account? <a href={siteConfig.appSignInUrl}>Sign in</a></p>

    <div class="signup-form-col">
      <SignUpForm />
    </div>

    <div class="divider"><span>or sign up with</span></div>
    <div class="google-btn-wrap" id="google-signup-page-btn"></div>
  </section>
</MainLayout>

<style>
  .page-sub {
    color: var(--muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  /* Match the standalone /sign-in page (max-width 360) and the divider/Google width below. */
  .signup-form-col {
    max-width: 360px;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.25rem 0 0.75rem;
    max-width: 360px;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .divider::before,
  .divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  .google-btn-wrap {
    max-width: 360px;
    min-height: 40px;
  }
</style>

<script>
  import { gqlSignInGoogle, friendlyAuthError } from "../utils/auth-graphql";
  import { loadGsi, initGoogleButton } from "../utils/google-auth";
  import { siteConfig } from "../config/site";

  const googleContainer = document.getElementById("google-signup-page-btn") as HTMLDivElement | null;
  const googleClientId = siteConfig.googleClientId;
  const errorEl = document.querySelector<HTMLParagraphElement>(".signup-error");

  // Google needs a client ID from PUBLIC_GOOGLE_CLIENT_ID (the backend no longer exposes one).
  if (googleContainer && googleClientId) {
    loadGsi()
      .then(() => {
        initGoogleButton(googleClientId, googleContainer, async (idToken) => {
          try {
            const result = await gqlSignInGoogle(siteConfig.graphqlUrl, idToken);
            if (result.ok) {
              window.location.href = `${siteConfig.appUrl}/?token=${result.token}`;
            } else if (errorEl) {
              errorEl.textContent = friendlyAuthError(result.message);
              errorEl.hidden = false;
            }
          } catch {
            if (errorEl) {
              errorEl.textContent = "Unable to reach the sign-up service. Please try again.";
              errorEl.hidden = false;
            }
          }
        });
      })
      .catch(() => {
        // Google button unavailable — email/password path still works
      });
  }
</script>
