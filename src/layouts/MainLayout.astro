---
import "../styles/global.css";
import { mainNav, siteConfig } from "../config/site";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title} | {siteConfig.productName}</title>
  </head>
  <body>
    <header>
      <div class="wrap">
        <strong>{siteConfig.productName}</strong>
        <nav aria-label="Main">
          {mainNav.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer>
      <div class="wrap">
        Public site for Crystord. SaaS sign-in is intentionally separated from this landing experience.
      </div>
    </footer>
  </body>
</html>
