---
import "../styles/global.css";
import { mainNav, signInLink, footerNav, siteConfig } from "../config/site";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title} | {siteConfig.productName}</title>
    <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
  </head>
  <body>
    <header>
      <div class="wrap">
        <a href="/" class="site-name">
          <img src={`${import.meta.env.BASE_URL}logo_negated.png`} alt={siteConfig.productName} class="nav-logo" />
          <span class="sr-only">{siteConfig.productName}</span>
        </a>
        <nav aria-label="Main">
          {mainNav.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
          <a href={signInLink.href}>{signInLink.label}</a>
        </nav>
      </div>
    </header>
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer>
      <div class="wrap">
        <nav class="footer-nav" aria-label="Footer">
          {footerNav.map((item) =>
            item.external ? (
              <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>
            ) : (
              <a href={item.href}>{item.label}</a>
            )
          )}
        </nav>
        <p class="footer-copy">&copy; {new Date().getFullYear()} {siteConfig.productName}. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
