---
import FormField from "./ui/FormField.astro";
import { siteConfig } from "../config/site";
---

<form class="sign-in-form" data-auth-url={siteConfig.appSignInUrl} novalidate>
  <FormField label="Email" name="si-email" type="email" required autocomplete="email" />
  <FormField label="Password" name="si-password" type="password" required autocomplete="current-password" />
  <p class="sign-in-error" hidden aria-live="polite"></p>
  <button type="submit" class="btn btn-primary">Sign In</button>
</form>

<style>
  .sign-in-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 360px;
  }

  .sign-in-error {
    color: var(--error);
    margin: 0;
    font-size: 0.9rem;
  }

  button[type="submit"] {
    align-self: flex-start;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-family: inherit;
  }

  button[type="submit"]:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script>
  import { submitSignIn } from "../utils/sign-in";

  document.querySelectorAll<HTMLFormElement>(".sign-in-form").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const authUrl = form.dataset.authUrl!;
      const email = form.querySelector<HTMLInputElement>("#si-email")!.value.trim();
      const password = form.querySelector<HTMLInputElement>("#si-password")!.value;
      const errorEl = form.querySelector<HTMLParagraphElement>(".sign-in-error")!;
      const submitBtn = form.querySelector<HTMLButtonElement>("button[type=submit]")!;

      errorEl.hidden = true;
      submitBtn.disabled = true;
      submitBtn.textContent = "Signing in…";

      try {
        const result = await submitSignIn(authUrl, email, password);
        if (result.ok) {
          window.location.href = result.redirectUrl;
        } else {
          errorEl.textContent = result.message;
          errorEl.hidden = false;
          submitBtn.disabled = false;
          submitBtn.textContent = "Sign In";
        }
      } catch {
        errorEl.textContent = "Unable to reach the sign-in service. Please try again.";
        errorEl.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = "Sign In";
      }
    });
  });
</script>
