---
interface Props {
  title: string;
  updatedAt: string;
}

const { title, updatedAt } = Astro.props;
---

<article class="panel policy">
  <h1>{title}</h1>
  <p class="meta">Last updated: {updatedAt}</p>

  <slot />

  {Astro.slots.has("trademark") && (
    <p class="trademark">
      <slot name="trademark" />
    </p>
  )}
</article>
